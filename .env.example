# ─────────────────────────────────────────────────────────────────────────────
# cha-bot-starter-kit — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Usage:
#   1) Copy this file to ".env" for local development:
#        cp .env.example .env
#   2) Fill in your own values as instructed below
#   3) For Vercel deployment, register the same variables in:
#        Project Settings → Environment Variables
#
# Security:
#   - Never commit .env to git (.gitignore already covers it)
#   - Variables prefixed with VITE_* are exposed to the browser
#     → Keep real secrets (server-only) without the VITE_ prefix
# ─────────────────────────────────────────────────────────────────────────────


# ─── On-Premise Server (LLM + RAG + Database) ───────────────────────────────
# Your own backend that handles chat completions, embeddings, and chat history.
# All chat / TTS / STT requests from the app are proxied through Vercel api/*.js
# functions to this server.
#
# Leave blank to run the starter kit in "frontend-only demo mode" (no chat).

ONPREMISE_BASE_URL=https://your-onpremise-server.example.com
ONPREMISE_API_KEY=your_api_key_here


# ─── Chat History (optional) ────────────────────────────────────────────────
# If set, every user/assistant message is POSTed to this endpoint for logging.
# Leave blank to disable chat history persistence.

VITE_CHAT_LOG_ENDPOINT=


# ─── OpenAI (optional fallback) ─────────────────────────────────────────────
# Used as fallback for STT/TTS if on-premise server is unavailable.

OPENAI_API_KEY=
