# ─────────────────────────────────────────────
# 보안 — 시크릿 절대 커밋 금지
# ─────────────────────────────────────────────
# 환경변수
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.env
# ↓ .env.example 은 템플릿이므로 커밋해야 함 (시크릿 미포함)
!.env.example

# API 키·토큰·자격증명
**/secrets/
**/credentials/
*credentials*.json
*service-account*.json
*.pem
*.key
*.cer
*.crt
*.p12
*.pfx

# LiveAvatar / HeyGen 관련 토큰·세션 파일
*livekit-token*
*heygen-token*
*api-key*

# ─────────────────────────────────────────────
# 빌드 산출물
# ─────────────────────────────────────────────
dist/
build/
out/
.vercel/
.next/
.cache/
.parcel-cache/

# ─────────────────────────────────────────────
# 의존성
# ─────────────────────────────────────────────
node_modules/
.pnp/
.pnp.js
.pnp.cjs
jspm_packages/

# ─────────────────────────────────────────────
# 로그·임시 파일
